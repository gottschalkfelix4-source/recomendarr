# Tautulli Configuration
TAUTULLI_URL=http://localhost:8181
TAUTULLI_API_KEY=your_tautulli_api_key_here

# Sonarr Configuration
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr Configuration
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

# Plex Configuration (optional)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here

# AI Provider Configuration (OpenAI-compatible)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o

# Note: These are just examples for reference.
# All settings are now managed through the web UI.
# Environment variables only used as fallback if not set via UI.
